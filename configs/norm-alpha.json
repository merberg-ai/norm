{
  "system": {
    "name": "N.O.R.M.",
    "full_name": "Neural Overseer for Routine Management",
    "version": "0.02-alpha-r4-memory",
    "profile": "pi5-alpha",
    "debug": true,
    "log_level": "INFO"
  },
  "display": {
    "enabled": true,
    "backend": "pygame",
    "width": 800,
    "height": 480,
    "fullscreen": true,
    "fps": 24,
    "hide_mouse": true,
    "rotate": 0,
    "effects": {
      "scanlines": true,
      "noise": true,
      "vignette": true,
      "glow": true,
      "crt_flicker": true,
      "glitch": true
    }
  },
  "theme": {
    "default": "norm_terminal_amber",
    "theme_dir": "themes",
    "allow_runtime_switching": true,
    "fallback": "norm_terminal_amber"
  },
  "touch": {
    "enabled": true,
    "backend": "evdev",
    "device": "/dev/input/event0",
    "match_name": "QDtech MPI5001",
    "invert_x": false,
    "invert_y": false,
    "swap_xy": false,
    "tap_debounce_seconds": 0.25,
    "tap_face_action": "none",
    "tap_header_action": "none"
  },
  "face": {
    "engine": "simple",
    "theme": "norm_terminal_amber",
    "startup_mode": "boot",
    "idle_mode": "idle",
    "show_status_text": true,
    "show_prompt_cursor": true,
    "show_scanlines": true,
    "allow_glitch": true,
    "default_status_text": "LISTENING...",
    "geometry": {
      "face_center": [
        400,
        210
      ],
      "left_eye": {
        "x": 170,
        "y": 145,
        "w": 185,
        "h": 70
      },
      "right_eye": {
        "x": 445,
        "y": 145,
        "w": 185,
        "h": 70
      },
      "left_brow": {
        "x": 165,
        "y": 125,
        "w": 195,
        "h": 12
      },
      "right_brow": {
        "x": 440,
        "y": 125,
        "w": 195,
        "h": 12
      },
      "mouth": {
        "x": 250,
        "y": 285,
        "w": 300,
        "h": 36
      },
      "status_text": {
        "x": 120,
        "y": 340,
        "w": 560,
        "h": 28
      }
    },
    "animations": {
      "blink_enabled": true,
      "blink_min_seconds": 4,
      "blink_max_seconds": 9,
      "blink_duration_ms": 140,
      "idle_drift_enabled": true,
      "idle_drift_range_x": 42,
      "idle_drift_range_y": 12,
      "cursor_blink_enabled": true,
      "cursor_blink_seconds": 0.55,
      "idle_glitch_enabled": true,
      "idle_glitch_min_seconds": 30,
      "idle_glitch_max_seconds": 90
    },
    "idle_behavior": {
      "enabled": true,
      "min_seconds": 35,
      "max_seconds": 90,
      "expression_min_seconds": 5,
      "expression_max_seconds": 11,
      "expressions": [
        "annoyed",
        "bored",
        "worried"
      ]
    }
  },
  "local_ui": {
    "enabled": true,
    "theme": "norm_terminal_amber",
    "default_display_mode": "face",
    "allow_touch_controls": true,
    "allow_config_screen": true,
    "allow_face_controls": true,
    "allow_camera_screen": true,
    "allow_audio_screen": true,
    "allow_diagnostics_screen": true,
    "idle_return_seconds": 60,
    "show_readonly_config": true,
    "allow_reboot_button": false,
    "allow_shutdown_button": false,
    "shutdown_requires_confirmation": true,
    "shutdown_confirmation_timeout_seconds": 5,
    "layout": {
      "outer_frame": {
        "x": 24,
        "y": 20,
        "w": 752,
        "h": 436
      },
      "header": {
        "x": 32,
        "y": 28,
        "w": 736,
        "h": 42
      },
      "nav_panel": {
        "x": 40,
        "y": 84,
        "w": 150,
        "h": 315
      },
      "main_panel": {
        "x": 205,
        "y": 84,
        "w": 555,
        "h": 315
      },
      "footer": {
        "x": 32,
        "y": 410,
        "w": 736,
        "h": 42
      }
    }
  },
  "web_ui": {
    "enabled": true,
    "theme": "norm_terminal_amber",
    "mobile_friendly": true,
    "show_dashboard": true,
    "show_face_controls": true,
    "show_camera_tests": true,
    "show_audio_tests": true,
    "show_config_summary": true,
    "show_logs": true,
    "style": {
      "terminal_panels": true,
      "amber_monochrome": true,
      "scanline_overlay": true,
      "large_touch_buttons": true
    },
    "show_brain_test": true
  },
  "api": {
    "enabled": true,
    "host": "0.0.0.0",
    "port": 8088,
    "require_auth": false
  },
  "camera": {
    "enabled": true,
    "type": "usb",
    "device": "/dev/video0",
    "resolution": [
      640,
      480
    ],
    "snapshot_path": "/tmp/norm_latest.jpg",
    "capture_command": "fswebcam",
    "flip_horizontal": false,
    "flip_vertical": false
  },
  "audio": {
    "input": {
      "enabled": true,
      "device": "plughw:2,0",
      "device_label": "Logitech Brio 100 microphone",
      "sample_rate": 16000,
      "channels": 1,
      "record_seconds": 5,
      "test_record_path": "/tmp/norm_mic_test.wav"
    },
    "output": {
      "enabled": true,
      "device": "plughw:3,0",
      "device_label": "Audio output disabled until USB speakers arrive",
      "volume_percent": 80,
      "startup_sound": "sounds/startup.wav",
      "error_sound": "sounds/error.wav",
      "allow_missing_device": true
    },
    "alternate_devices": {
      "input_usb_pnp": "plughw:3,0",
      "output_hdmi_0": "plughw:1,0",
      "output_hdmi_1": "plughw:2,0",
      "output_usb_speakers": "pending"
    }
  },
  "brain": {
    "enabled": true,
    "provider": "ollama",
    "host": "http://192.168.1.24:11434",
    "chat_model": "norm-alpha",
    "vision_model": "llama3.2-vision",
    "timeout_seconds": 60,
    "stream": false,
    "speaking_hold_seconds": 4,
    "max_prompt_chars": 2000,
    "include_raw": false
  },
  "hardware": {
    "platform": "pi5",
    "usb_hub_required": true,
    "touchscreen": {
      "type": "usb",
      "name": "QDtech MPI5001"
    },
    "camera": {
      "type": "usb",
      "name": "Logitech Brio 100"
    },
    "audio_input": {
      "primary": "Logitech Brio 100 microphone",
      "alternate": "USB PnP Sound Device"
    },
    "audio_output": {
      "primary": "HDMI 0",
      "alternate": "HDMI 1",
      "usb_speakers_pending": true
    },
    "picam": {
      "enabled": false
    },
    "picar_hat": {
      "enabled": false
    },
    "rgb": {
      "enabled": false
    },
    "servos": {
      "enabled": false
    },
    "motors": {
      "enabled": false,
      "movement_allowed": false
    }
  },
  "safety": {
    "movement_allowed": false,
    "require_manual_enable_for_motors": true,
    "max_motion_duration_ms": 500,
    "emergency_stop_enabled": true
  },
  "power": {
    "enabled": false,
    "execute_commands": false,
    "notes": "OS reboot/shutdown are intentionally not available from the local UI in alpha. Use SSH or systemd scripts."
  },
  "service": {
    "enabled_by_default": false,
    "service_name": "norm-face.service",
    "install_script": "scripts/install_service.sh",
    "logs_script": "scripts/service_logs.sh",
    "notes": "Manual run remains default during development. Install service when ready for boot-to-face behavior."
  },
  "speech": {
    "tts": {
      "enabled": true,
      "provider": "espeak-ng",
      "voice_preset": "creepy_terminal",
      "voice": "en-us+m3",
      "speed": 130,
      "pitch": 28,
      "amplitude": 135,
      "word_gap": 5,
      "output_path": "/tmp/norm_tts.wav",
      "test_phrase": "Routine oversight is active. Your compliance has been logged.",
      "max_spoken_chars": 500,
      "speak_brain_responses_by_default": true,
      "synthesis_timeout_seconds": 30,
      "future_providers": [
        "piper",
        "remote"
      ]
    }
  },
  "memory": {
    "enabled": true,
    "database_path": "data/norm_memory.sqlite3",
    "session_id": "default",
    "max_recent_messages": 16,
    "include_recent_messages": true,
    "include_session_summary": false,
    "include_long_term_memories": false,
    "max_long_term_memories": 8,
    "auto_save_messages": true,
    "inject_system_prompt": true,
    "max_memory_block_chars": 6000,
    "max_runtime_context_chars": 2000,
    "vector_enabled": false,
    "embedding_provider": "ollama",
    "embedding_model": "nomic-embed-text",
    "vector_top_k": 5,
    "vector_min_score": 0.65,
    "notes": "Phase 1 uses plain SQLite for recent chat recall. sqlite-vec semantic memory arrives in the next brain phase."
  },
  "identity": {
    "enabled": false,
    "people_enabled": false,
    "camera_recognition_enabled": false,
    "voice_recognition_enabled": false,
    "fusion_enabled": false,
    "ask_unknown_people": true,
    "recognized_confidence_threshold": 0.85,
    "unknown_confidence_threshold": 0.5,
    "offload": {
      "enabled": false,
      "host": "http://192.168.1.24:8091",
      "timeout_seconds": 20,
      "fallback_to_local": true
    },
    "notes": "Reserved for the future people/voice/camera recognition system."
  }
}
